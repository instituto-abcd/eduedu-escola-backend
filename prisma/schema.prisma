generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enum for status
enum Status {
  ACTIVE
  INACTIVE
}

// Enum for Profile
enum Profile {
  DIRECTOR
  TEACHER
}

// Model for School
model School {
  id          String        @id @default(uuid())
  name        String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  users       User[]
  schoolYear  SchoolYear[]
  schoolClass SchoolClass[]
  Settings    Settings[]
}

// Model for SchoolClass
model SchoolClass {
  id           String               @id @default(uuid())
  name         String
  schoolGrade  SchoolGradeEnum
  schoolPeriod SchoolPeriodEnum
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  schoolYearId String
  schoolYear   SchoolYear           @relation(fields: [schoolYearId], references: [id])
  users        UserSchoolClass[]
  students     SchoolClassStudent[]
  schoolId     String?
  School       School?              @relation(fields: [schoolId], references: [id])

  @@unique([name, schoolYearId, schoolGrade, schoolPeriod])
}

// Enum for SchoolGrade
enum SchoolGradeEnum {
  CHILDREN
  FIRST_GRADE
  SECOND_GRADE
  THIRD_GRADE
}

// Enum for SchoolPeriod
enum SchoolPeriodEnum {
  MORNING
  AFTERNOON
  FULL
}

// Enum for StatusSchoolYear
enum StatusSchoolYear {
  ACTIVE
  INACTIVE
  DRAFT
}

// Model for SchoolYear
model SchoolYear {
  id            String           @id @default(uuid())
  name          Int
  status        StatusSchoolYear @default(DRAFT)
  schoolId      String
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  school        School           @relation(fields: [schoolId], references: [id])
  schoolClasses SchoolClass[]
}

// Model for Student
model Student {
  id        String   @id @default(uuid())
  name      String
  registry  String   @default("")
  status    Status   @default(ACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schoolClasses SchoolClassStudent[]
  studentAwards StudentAward[]
  examResults   StudentExamResult[]
  planetResult  StudentPlanetResult[]

  @@unique([id, name, registry])
}

model StudentExamResult {
  id            String   @default(uuid())
  studentExamId String
  axisCode      String
  percent       Decimal
  level         String
  resume        String
  examDate      DateTime @default(now())
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId     String

  @@id([studentExamId, axisCode, studentId])
}

model StudentPlanetResult {
  id            String   @default(uuid())
  studentExamId String
  planetId      String
  planetName    String
  axisCode      String
  stars         Decimal
  lastExecution DateTime @default(now())
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId     String

  @@id([studentExamId, planetId, studentId])
}

// Model for User
model User {
  id               String             @id @default(uuid())
  owner            Boolean            @default(false)
  status           Status             @default(ACTIVE)
  emailConfirmed   Boolean            @default(false)
  password         String?
  accessKey        String             @unique @default("")
  name             String
  email            String             @unique
  document         String             @unique
  profile          Profile            @default(TEACHER)
  schoolId         String
  school           School             @relation(fields: [schoolId], references: [id])
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  authTokens       AuthToken[]
  userSchoolClass  UserSchoolClass[]
  UserNotification UserNotification[]
  Audit            Audit[]
}

// Model for UserSchoolClass
model UserSchoolClass {
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  schoolClassId String
  schoolClass   SchoolClass @relation(fields: [schoolClassId], references: [id])

  @@id([userId, schoolClassId])
}

// Model for SchoolClassStudent
model SchoolClassStudent {
  schoolClassId String
  schoolClass   SchoolClass @relation(fields: [schoolClassId], references: [id])
  studentId     String
  student       Student     @relation(fields: [studentId], references: [id])
  active        Boolean     @default(true)
  reserved      Boolean     @default(false)
  firstAccess   Boolean     @default(true)

  @@id([studentId, schoolClassId])
}

// Model for SchoolClassStudent
model Award {
  id            String         @id @default(uuid())
  name          String
  title         String
  description   String
  studentAwards StudentAward[]
}

// Model for SchoolClassStudent
model StudentAward {
  id        String  @default(uuid())
  award     Award   @relation(fields: [awardId], references: [id])
  awardId   String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId String

  @@id([awardId, studentId])
}

// Model for AuthToken
model AuthToken {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Model for Settings
model Settings {
  id                     String   @id @default(uuid())
  synchronizationPlanets Boolean
  smtpHostName           String
  smtpUserName           String
  smtpPassword           String
  smtpPort               Int
  sslIsActive            Boolean
  schoolId               String   @unique
  school                 School   @relation(fields: [schoolId], references: [id])
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

// Model for Dashboard
model Dashboard {
  id                    String                 @id @default(uuid())
  schoolYear            Int
  teachersCounter       Int
  schoolClassesCounter  Int
  studentsCounter       Int
  dashboardSchoolGrades DashboardSchoolGrade[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
}

// Model for DashboardSchoolGrade
model DashboardSchoolGrade {
  id                   String                 @id @default(uuid())
  name                 SchoolGradeEnum
  teachersCounter      Int
  schoolClassesCounter Int
  studentsCounter      Int
  dashboardSchoolClass DashboardSchoolClass[]
  dashboardPerformance DashboardPerformance[]
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  dashboardId          String
  dashboard            Dashboard              @relation(fields: [dashboardId], references: [id])
}

// Model for DashboardSchoolClass
model DashboardSchoolClass {
  id                    String                 @id @default(uuid())
  name                  String
  studentsCounter       Int
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  dashboardGradeId      String
  dashboardGrade        DashboardSchoolGrade   @relation(fields: [dashboardGradeId], references: [id])
  dashboardPerformances DashboardPerformance[]
}

// Model for DashboardPerformance
model DashboardPerformance {
  id                     String                @id @default(uuid())
  axis                   String
  result                 Decimal               @default(0)
  type                   String
  level                  String                @default("0")
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  dashboardSchoolClassId String
  dashboardSchoolClass   DashboardSchoolClass  @relation(fields: [dashboardSchoolClassId], references: [id])
  DashboardSchoolGrade   DashboardSchoolGrade? @relation(fields: [dashboardSchoolGradeId], references: [id])
  dashboardSchoolGradeId String?
}

// Enum for Axis
enum AxisEnum {
  PHONOLOGICAL_AWARENESS
  ALPHABETIC_WRITING_SYSTEM
  READING_AND_TEXT_COMPREHENSION
}

model Notification {
  id               String             @id @default(uuid())
  text             String
  profiles         Profile[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  UserNotification UserNotification[]
}

model UserNotification {
  id             String       @id @default(uuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  notificationId String
  notification   Notification @relation(fields: [notificationId], references: [id])
  read           Boolean      @default(false)
}

model Audit {
  id        String   @id @default(uuid())
  action    String
  entity    String
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}
