generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enum for status
enum Status {
  ACTIVE
  INACTIVE
}

// Enum for Profile
enum Profile {
  DIRECTOR
  TEACHER
}

// Model for School
model School {
  id          String        @id @default(uuid())
  name        String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  users       User[]
  schoolYear  SchoolYear[]
  schoolClass SchoolClass[]
  Settings    Settings[]
}

// Model for SchoolClass
model SchoolClass {
  id           String               @id @default(uuid())
  name         String
  schoolGrade  String
  schoolPeriod String
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  schoolYearId String
  schoolYear   SchoolYear           @relation(fields: [schoolYearId], references: [id])
  users        UserSchoolClass[]
  students     SchoolClassStudent[]
  schoolId     String?
  School       School?              @relation(fields: [schoolId], references: [id])
}

enum StatusSchoolYear {
  ACTIVE
  INACTIVE
  DRAFT
}

// Model for SchoolYear
model SchoolYear {
  id            String           @id @default(uuid())
  name          Int
  status        StatusSchoolYear @default(DRAFT)
  schoolId      String
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  school        School           @relation(fields: [schoolId], references: [id])
  schoolClasses SchoolClass[]
}

// Model for Student
model Student {
  id            String               @id @default(uuid())
  name          String
  registry      String               @default("")
  status        Status               @default(ACTIVE)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  schoolClasses SchoolClassStudent[]
}

// Model for User
model User {
  id              String            @id @default(uuid())
  status          Status            @default(ACTIVE)
  password        String
  accessKey       String            @unique @default("")
  name            String
  email           String            @unique
  document        String            @unique
  profile         Profile           @default(TEACHER)
  schoolId        String
  school          School            @relation(fields: [schoolId], references: [id])
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  authTokens      AuthToken[]
  userSchoolClass UserSchoolClass[]
}

// Model for UserSchoolClass
model UserSchoolClass {
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  schoolClassId String
  schoolClass   SchoolClass @relation(fields: [schoolClassId], references: [id])

  @@id([userId, schoolClassId])
}

// Model for SchoolClassStudent
model SchoolClassStudent {
  schoolClassId String
  schoolClass   SchoolClass @relation(fields: [schoolClassId], references: [id])
  studentId     String
  student       Student     @relation(fields: [studentId], references: [id])

  @@id([schoolClassId, studentId])
}

// Model for AuthToken
model AuthToken {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}

// Model for Settings
model Settings {
  id                     String   @id @default(uuid())
  synchronizationPlanets Boolean
  smtpHostName           String
  smtpUserName           String
  smtpPassword           String
  sslIsActive            Boolean
  schoolId               String   @unique
  school                 School   @relation(fields: [schoolId], references: [id])
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}
